# Rust build artifacts
/target/
**/target/
**/*.rs.bk

# Trunk (wasm build output)
/dist/

# Tauri generated schemas
/src-tauri/gen/schemas/

# Generated icon source PNG (regenerable from source.svg via resvg)
# (Keep src-tauri/icons/source.svg, generated platform icons, and source.png
#  — only ignore intermediate renders here.)

# IDE / editor
.idea/
.vscode/
*.swp
*.swo
*~

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Node modules (if any tooling pulls them later)
node_modules/

# Claude Code per-machine state — settings.local.json, scheduled task locks,
# anything else that shouldn't be shared between checkouts.
/.claude/*
!/.claude/settings.json

# Env files / secrets
.env
.env.local
.env.*.local
